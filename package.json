{
  "name": "pi-multi-team-local",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli/main.tsx start",
    "dev": "tsx watch src/cli/main.tsx start",
    "demo": "tsx src/cli/main.tsx demo",
    "check-env": "tsx src/cli/main.tsx check-env",
    "policy-check": "tsx src/cli/main.tsx policy-check",
    "test": "tsx src/cli/shell-guard.test.ts && tsx src/agents/prompt-build.test.ts",
    "check": "npm run typecheck && npm run lint && npm test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src config scripts",
    "verify:playground": "npm run verify-tier2 && npm run verify-tier3 && npm run pi-play:verify-if-available",
    "verify-tier2": "node scripts/verify-tier2.mjs",
    "verify-tier3": "node scripts/verify-tier3.mjs",
    "inspect-session": "tsx src/cli/main.tsx inspect-session",
    "replay": "tsx src/cli/main.tsx replay",
    "export-timeline": "tsx src/cli/main.tsx export",
    "pi-play:default": "pi",
    "pi-play:pure-focus": "pi -e extensions/pure-focus.ts",
    "pi-play:minimal": "pi -e extensions/minimal.ts -e extensions/theme-cycler.ts",
    "pi-play:cross-agent": "pi -e extensions/cross-agent.ts -e extensions/minimal.ts",
    "pi-play:purpose-gate": "pi -e extensions/purpose-gate.ts -e extensions/minimal.ts",
    "pi-play:tool-counter": "pi -e extensions/tool-counter.ts",
    "pi-play:tool-counter-widget": "pi -e extensions/tool-counter-widget.ts -e extensions/minimal.ts -e extensions/theme-cycler.ts",
    "pi-play:subagent-widget": "pi -e extensions/subagent-widget.ts -e extensions/pure-focus.ts -e extensions/theme-cycler.ts",
    "pi-play:tilldone": "pi -e extensions/tilldone.ts -e extensions/theme-cycler.ts",
    "pi-play:agent-team": "pi -e extensions/agent-team.ts -e extensions/theme-cycler.ts",
    "pi-play:system-select": "pi -e extensions/system-select.ts -e extensions/minimal.ts -e extensions/theme-cycler.ts",
    "pi-play:damage-control": "pi -e extensions/damage-control.ts -e extensions/minimal.ts -e extensions/theme-cycler.ts",
    "pi-play:agent-chain": "pi -e extensions/agent-chain.ts -e extensions/theme-cycler.ts",
    "pi-play:pi-pi": "pi -e extensions/pi-pi.ts -e extensions/theme-cycler.ts",
    "pi-play:session-replay": "pi -e extensions/session-replay.ts -e extensions/minimal.ts",
    "pi-play:theme-cycler": "pi -e extensions/theme-cycler.ts -e extensions/minimal.ts",
    "pi-play:verify": "node scripts/verify-pi-play.mjs",
    "pi-play:verify-if-available": "node scripts/pi-play-verify-if-available.mjs",
    "pi-tier:v0": "pi",
    "pi-tier:v1": "pi -e extensions/pure-focus.ts",
    "pi-tier:v2": "pi -e extensions/minimal.ts -e extensions/theme-cycler.ts",
    "pi-tier:v3": "pi -e extensions/cross-agent.ts -e extensions/minimal.ts",
    "pi-tier:v4": "pi -e extensions/purpose-gate.ts -e extensions/minimal.ts",
    "pi-tier:v5": "pi -e extensions/tool-counter.ts",
    "pi-tier:v6": "pi -e extensions/tool-counter-widget.ts -e extensions/minimal.ts -e extensions/theme-cycler.ts",
    "pi-tier:v7": "pi -e extensions/subagent-widget.ts -e extensions/pure-focus.ts -e extensions/theme-cycler.ts",
    "pi-tier:v8": "pi -e extensions/tilldone.ts -e extensions/theme-cycler.ts",
    "pi-tier:v9": "pi -e extensions/agent-team.ts -e extensions/theme-cycler.ts",
    "pi-tier:v10": "pi -e extensions/system-select.ts -e extensions/minimal.ts -e extensions/theme-cycler.ts",
    "pi-tier:v11": "pi -e extensions/damage-control.ts -e extensions/minimal.ts -e extensions/theme-cycler.ts",
    "pi-tier:v12": "pi -e extensions/agent-chain.ts -e extensions/theme-cycler.ts",
    "pi-tier:v13": "pi -e extensions/pi-pi.ts -e extensions/theme-cycler.ts"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.65.0",
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "eventemitter3": "^5.0.1",
    "execa": "^9.5.2",
    "fs-extra": "^11.2.0",
    "ink": "^5.0.1",
    "minimatch": "^10.0.1",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
