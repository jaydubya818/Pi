{
  "name": "pi-multi-team-local",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli/main.tsx start",
    "dev": "tsx watch src/cli/main.tsx start",
    "demo": "tsx src/cli/main.tsx demo",
    "check-env": "tsx src/cli/main.tsx check-env",
    "policy-check": "tsx src/cli/main.tsx policy-check",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src config scripts",
    "inspect-session": "tsx src/cli/main.tsx inspect-session",
    "replay": "tsx src/cli/main.tsx replay",
    "export-timeline": "tsx src/cli/main.tsx export"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.65.0",
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "eventemitter3": "^5.0.1",
    "execa": "^9.5.2",
    "fs-extra": "^11.2.0",
    "ink": "^5.0.1",
    "minimatch": "^10.0.1",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
