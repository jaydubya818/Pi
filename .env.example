# ── Pi Coding Agent — API Keys ────────────────────────────────────────────────
# Copy to .env (already in .gitignore), fill in real values, then:
#   source .env && pi                          # or: direnv allow
#
# At least one key is required depending on your configured Pi model provider.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# Firecrawl — used by the Pi Pi meta-agent (extensions/pi-pi.ts) to fetch
# live Pi documentation at query time. Optional; experts still run without it.
FIRECRAWL_API_KEY=fc-...

# ── Playground label ─────────────────────────────────────────────────────────
# Set automatically by npm run pi-play:* and pi-tier:* scripts.
# Shows a startup notification with the preset name. Leave unset when running
# extensions directly via: pi -e extensions/<name>.ts
# PI_PLAYGROUND_LABEL=my-session-name

# ── Pi binary overrides (rarely needed) ──────────────────────────────────────
# PI_MOCK=1        # use Pi's built-in mock provider (no API key required)
# PI_BINARY=       # path to a specific pi binary if not on PATH
