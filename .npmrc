# Ensure optional platform-specific dependencies (esbuild, @biomejs/*) are
# always installed. These contain the native binaries for lint (biome) and
# test (tsx → esbuild). Without them, npm run lint and npm test fail.
#
# If you switch machines (e.g. macOS → Linux) and see esbuild/biome errors,
# run:  npm install   (or npm ci)  to reinstall for the current platform.
optional=true
